    "title": "\u0906\u092a\u0915\u0940 \u091f\u0949\u0915\u094d\u0938\u093f\u0915 \u0906\u0926\u0924 \u0915\u094d\u092f\u093e \u0939\u0948?",
    "desc": "\u0939\u0930 \u0915\u093f\u0938\u0940 \u092e\u0947\u0902 \u090f\u0915 \u0939\u094b\u0924\u0940 \u0939\u0948\u0964 8 \u0930\u094b\u091c\u093c\u092e\u0930\u094d\u0930\u093e \u0915\u0947 \u0938\u093f\u0928\u0947\u0930\u093f\u092f\u094b \u0938\u0947 \u0905\u092a\u0928\u0940 \u091b\u0941\u092a\u0940 \u091f\u0949\u0915\u094d\u0938\u093f\u0915 \u0906\u0926\u0924 \u0916\u094b\u091c\u0947\u0902\u0964",
    "chip1": "8 \u0938\u0935\u093e\u0932",
    "chip2": "\u0932\u0917\u092d\u0917 2 \u092e\u093f\u0928\u091f",
    "chip3": "6 \u092a\u094d\u0930\u0915\u093e\u0930",
    "socialProof": "{count}+ \u0932\u094b\u0917\u094b\u0902 \u0928\u0947 \u0905\u092a\u0928\u0940 \u091f\u0949\u0915\u094d\u0938\u093f\u0915 \u0906\u0926\u0924 \u0916\u094b\u091c \u0932\u0940",
    "disclaimer": "\u092f\u0939 \u091f\u0947\u0938\u094d\u091f \u0938\u093f\u0930\u094d\u092b\u093c \u092e\u091c\u093c\u0947 \u0914\u0930 \u0906\u0924\u094d\u092e-\u091a\u093f\u0902\u0924\u0928 \u0915\u0947 \u0932\u093f\u090f \u0939\u0948, \u0915\u094d\u0932\u093f\u0928\u093f\u0915\u0932 \u092e\u0942\u0932\u094d\u092f\u093e\u0902\u0915\u0928 \u0928\u0939\u0940\u0902\u0964",
    "start": "\u092e\u0947\u0930\u0940 \u091f\u0949\u0915\u094d\u0938\u093f\u0915 \u0906\u0926\u0924 \u0916\u094b\u091c\u0947\u0902"
