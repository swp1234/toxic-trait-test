    "chronicComparerDesc": "\u0926\u0942\u0938\u0930\u094b\u0902 \u0915\u0940 \u0939\u093e\u0907\u0932\u093e\u0907\u091f \u0930\u0940\u0932 \u0938\u0947 \u0938\u092b\u0932\u0924\u093e \u092e\u093e\u092a\u0924\u0947 \u0939\u0948\u0902\u0964",
    "chronicComparerEmoji": "\u2696\ufe0f"
  },
  "question": {
    "0": "\u0926\u094b\u0938\u094d\u0924 \u0928\u0947 \u092e\u0948\u0938\u0947\u091c \u0915\u093f\u092f\u093e \"\u0939\u092e\u0947\u0902 \u092c\u093e\u0924 \u0915\u0930\u0928\u0940 \u0939\u0948\"\u0964 \u0906\u092a \u0915\u094d\u092f\u093e \u0915\u0930\u0947\u0902\u0917\u0947?",
    "1": "\u0915\u093f\u0938\u0940 \u0928\u0947 \u0911\u092b\u093f\u0938 \u092e\u0947\u0902 \u0906\u092a\u0915\u0947 \u0906\u0907\u0921\u093f\u092f\u093e \u0915\u093e \u0936\u094d\u0930\u0947\u092f \u0932\u0947 \u0932\u093f\u092f\u093e\u0964",
    "2": "\u0926\u094b\u0938\u094d\u0924\u094b\u0902 \u0915\u0947 \u0938\u093e\u0925 \u092a\u094d\u0932\u093e\u0928 \u0939\u0948 \u0932\u0947\u0915\u093f\u0928 \u0938\u094b\u092b\u093e \u092c\u0939\u0941\u0924 \u0906\u0930\u093e\u092e\u0926\u093e\u092f\u0915 \u0932\u0917 \u0930\u0939\u093e \u0939\u0948\u0964",
    "3": "\u0926\u094b\u0938\u094d\u0924 \u0928\u0947 \u0936\u093e\u0928\u0926\u093e\u0930 \u091b\u0941\u091f\u094d\u091f\u093f\u092f\u094b\u0902 \u0915\u0940 \u092b\u094b\u091f\u094b \u092a\u094b\u0938\u094d\u091f \u0915\u0940 \u0914\u0930 \u0906\u092a \u0915\u093e\u092e \u092a\u0930 \u092b\u0902\u0938\u0947 \u0939\u0948\u0902\u0964",
    "4": "\u0906\u092a\u0928\u0947 \u0926\u094b\u0938\u094d\u0924 \u0915\u094b \u0907\u0938 \u0935\u0940\u0915\u0947\u0902\u0921 \u0936\u093f\u092b\u094d\u091f\u093f\u0902\u0917 \u092e\u0947\u0902 \u092e\u0926\u0926 \u0915\u0930\u0928\u0947 \u0915\u093e \u0935\u093e\u0926\u093e \u0915\u093f\u092f\u093e\u0964",
    "5": "\u0915\u093f\u0938\u0940 \u0928\u0947 \u092a\u0942\u091b\u093e \"\u0915\u094d\u092f\u093e \u0924\u0941\u092e \u092e\u0941\u091d\u0938\u0947 \u0928\u093e\u0930\u093e\u091c\u093c \u0939\u094b?\"",
    "6": "\u0906\u092a\u0915\u0947 \u0926\u094b\u0938\u094d\u0924 \u0915\u094b \u092c\u0921\u093c\u0940 \u092a\u094d\u0930\u092e\u094b\u0936\u0928 \u092e\u093f\u0932\u0940\u0964",
    "7": "\u0906\u092a \u0915\u093f\u0938\u0940 \u0938\u0947 \u092e\u093f\u0932\u0928\u0947 \u091c\u093e \u0930\u0939\u0947 \u0939\u0948\u0902 \u0914\u0930 20 \u092e\u093f\u0928\u091f \u0932\u0947\u091f \u0939\u094b \u0930\u0939\u0947 \u0939\u0948\u0902\u0964"
  },
  "option": {
    "0a": "\u092a\u0922\u093c\u0924\u0947 \u0939\u0948\u0902, \u0918\u092c\u0930\u093e\u0924\u0947 \u0939\u0948\u0902, \u0914\u0930 3 \u0926\u093f\u0928 \u0924\u0915 \u091c\u0935\u093e\u092c \u0928\u0939\u0940\u0902 \u0926\u0947\u0924\u0947",
    "0b": "\u0924\u0941\u0930\u0902\u0924 \u092e\u093e\u092b\u0940 \u0915\u0940 \u0938\u094d\u092a\u0940\u091a \u0924\u0948\u092f\u093e\u0930 \u0915\u0930\u0928\u093e \u0936\u0941\u0930\u0942 \u0915\u0930 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",
    "0c": "\"\u0939\u093e\u0902, \u0915\u094d\u092f\u093e \u0939\u0941\u0906?\" \u0915\u0939\u0915\u0930 4 \u0918\u0902\u091f\u0947 \u0938\u092d\u0940 \u0938\u0902\u092d\u0935 \u0905\u0930\u094d\u0925\u094b\u0902 \u0915\u093e \u0935\u093f\u0936\u094d\u0932\u0947\u0937\u0923 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "0d": "\u092a\u0942\u0930\u093e \u092e\u0948\u0938\u0947\u091c \u092a\u0922\u093c\u0947 \u092c\u093f\u0928\u093e \"\u0939\u093e\u0939\u093e \u0938\u0947\u092e\" \u0915\u0939\u0915\u0930 \u091c\u0935\u093e\u092c \u0926\u0947 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",
    "1a": "\u0915\u0941\u091b \u0928\u0939\u0940\u0902 \u0915\u0939\u0924\u0947 \u0932\u0947\u0915\u093f\u0928 \u092a\u0948\u0938\u093f\u0935\u0932\u0940 \u0938\u092d\u0940 \u0915\u094b CC \u092e\u0947\u0902 \u0913\u0930\u093f\u091c\u093f\u0928\u0932 \u0908\u092e\u0947\u0932 \u092d\u0947\u091c\u0924\u0947 \u0939\u0948\u0902",
    "1b": "\u0926\u093f\u092e\u093e\u0917 \u092e\u0947\u0902 \u0924\u094b \u0932\u0921\u093c\u0924\u0947 \u0939\u0948\u0902... \u0905\u0938\u0932 \u092e\u0947\u0902 \u092e\u0941\u0938\u094d\u0915\u0941\u0930\u093e\u0915\u0930 \u0905\u0902\u0926\u0930 \u0938\u0947 \u091f\u0942\u091f\u0924\u0947 \u0939\u0948\u0902",
    "1c": "\u092c\u0924\u093e\u0928\u093e \u0936\u0941\u0930\u0942 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a\u0928\u0947 \u0935\u094b \u0906\u0907\u0921\u093f\u092f\u093e \u0915\u0948\u0938\u0947 \u0938\u094b\u091a\u093e, \u0905\u092a\u0928\u0940 \u092a\u094d\u0930\u0924\u093f\u092d\u093e \u092a\u0930 \u092c\u093e\u0924 \u0918\u0941\u092e\u093e\u0924\u0947 \u0939\u0948\u0902",
    "1d": "\u0924\u0941\u0930\u0902\u0924 \u0909\u0928\u0938\u0947 \u0924\u0941\u0932\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0938\u094b\u091a\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0915\u094d\u092f\u093e \u0906\u092a \u0938\u091a\u092e\u0941\u091a \u0905\u091a\u094d\u091b\u0947 \u0939\u0948\u0902",
    "2a": "\u0926\u093f\u0928\u092d\u0930 \u092c\u0928\u093e\u090f \u0915\u094d\u0930\u093f\u090f\u091f\u093f\u0935 \u092c\u0939\u093e\u0928\u0947 \u0938\u0947 \u0915\u0948\u0902\u0938\u0932 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "2b": "\u091c\u093e\u0924\u0947 \u0939\u0948\u0902 \u0932\u0947\u0915\u093f\u0928 \u092a\u0942\u0930\u0947 \u0938\u092e\u092f \u0936\u093f\u0915\u093e\u092f\u0924 \u0915\u0930\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902",
    "2c": "\u0938\u094b\u092b\u0947 \u0915\u0940 \u092b\u094b\u091f\u094b \u092a\u094b\u0938\u094d\u091f \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \"\u0915\u092d\u0940-\u0915\u092d\u0940 \u0938\u0947\u0932\u094d\u092b-\u0915\u0947\u092f\u0930 \u091c\u0940\u0924\u0924\u093e \u0939\u0948\" \u0914\u0930 \u0917\u094d\u0930\u0941\u092a \u091a\u0948\u091f \u0907\u0917\u094d\u0928\u094b\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "2d": "\u091c\u093e\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0938\u092d\u0940 \u0915\u094b \u092c\u0924\u093e\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a \u0932\u0917\u092d\u0917 \u0918\u0930 \u092a\u0930 \u0930\u0939 \u091c\u093e\u0924\u0947",
    "3a": "\u092b\u094b\u091f\u094b \u0932\u093e\u0907\u0915 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0905\u0902\u0926\u0930 \u0938\u0947 \u0909\u0928\u0915\u0940 \u091c\u093f\u0902\u0926\u0917\u0940 \u0938\u0947 \u0905\u092a\u0928\u0940 \u0924\u0941\u0932\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "3b": "\u0909\u0928\u0938\u0947 \u0906\u0917\u0947 \u0928\u093f\u0915\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0924\u0941\u0930\u0902\u0924 \u0905\u092a\u0928\u0940 \u091b\u0941\u091f\u094d\u091f\u0940 \u092a\u094d\u0932\u093e\u0928 \u0915\u0930\u0928\u0947 \u0932\u0917\u0924\u0947 \u0939\u0948\u0902",
    "3c": "\u0938\u092a\u094b\u0930\u094d\u091f\u093f\u0935 \u0915\u0949\u092e\u0947\u0902\u091f \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u092b\u093f\u0930 \u0915\u093f\u0938\u0940 \u0914\u0930 \u0938\u0947 \u092c\u093e\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u091c\u093f\u0902\u0926\u0917\u0940 \u0915\u093f\u0924\u0928\u0940 \u0905\u0928\u094d\u092f\u093e\u092f\u0940 \u0939\u0948",
    "3d": "\u092e\u093e\u0928\u0938\u093f\u0915 \u0938\u094d\u0935\u093e\u0938\u094d\u0925\u094d\u092f \u0915\u0947 \u0932\u093f\u090f \u0909\u0928\u0915\u0940 \u0938\u094d\u091f\u094b\u0930\u0940\u091c\u093c \u092e\u094d\u092f\u0942\u091f \u0915\u0930 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",
    "4a": "\u0926\u0947\u0930 \u0938\u0947 \u0915\u0949\u092b\u0940 \u0932\u0947\u0915\u0930 \u0906\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u091c\u094d\u092f\u093e\u0926\u093e\u0924\u0930 \u0938\u0941\u092a\u0930\u0935\u093e\u0907\u091c\u093c \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "4b": "\u0938\u0941\u092c\u0939 \u0938\u0902\u0926\u0947\u0939\u093e\u0938\u094d\u092a\u0926 \u0930\u0942\u092a \u0938\u0947 \u0935\u093f\u0936\u0947\u0937 \u092c\u0939\u093e\u0928\u0947 \u0938\u0947 \u0915\u0948\u0902\u0938\u0932 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "4c": "\u091c\u093e\u0924\u0947 \u0939\u0948\u0902 \u0932\u0947\u0915\u093f\u0928 \u092a\u0942\u0930\u0947 \u0938\u092e\u092f \u092c\u0924\u093e\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a\u0915\u0940 \u092a\u093f\u091b\u0932\u0940 \u0936\u093f\u092b\u094d\u091f\u093f\u0902\u0917 \u0915\u093f\u0924\u0928\u0940 \u092e\u0941\u0936\u094d\u0915\u093f\u0932 \u0925\u0940",
    "4d": "\u0939\u093e\u0902 \u0915\u0939\u0924\u0947 \u0939\u0948\u0902 \u0932\u0947\u0915\u093f\u0928 \u0909\u0938\u0940 \u0926\u093f\u0928 3 \u0914\u0930 \u0932\u094b\u0917\u094b\u0902 \u0915\u094b \u092d\u0940 \u0905\u0932\u0917-\u0905\u0932\u0917 \u0935\u093e\u0926\u0947 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "5a": "\"\u0920\u0940\u0915 \u0939\u0942\u0902\" (\u0920\u0940\u0915 \u0928\u0939\u0940\u0902 \u0939\u0948\u0902)",
    "5b": "\"\u092d\u093e\u0935\u0928\u093e\u0913\u0902 \u0915\u094b \u0938\u0941\u0932\u091d\u093e\u0928\u0947\" \u0915\u0947 \u0932\u093f\u090f \u090f\u0915 \u0926\u093f\u0928 \u0907\u0917\u094d\u0928\u094b\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "5c": "\u0905\u092a\u0928\u0940 \u092d\u093e\u0935\u0928\u093e\u0913\u0902 \u0914\u0930 \u0906\u092a \u0915\u0948\u0938\u0947 \u092a\u094d\u0930\u092d\u093e\u0935\u093f\u0924 \u0939\u0941\u090f \u0907\u0938 \u092a\u0930 20 \u092e\u093f\u0928\u091f \u0915\u093e \u092d\u093e\u0937\u0923 \u0936\u0941\u0930\u0942 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902",
    "5d": "\u0928\u0939\u0940\u0902 \u0915\u0939\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0924\u0941\u0930\u0902\u0924 \u0909\u0928\u0915\u093e Instagram \u091a\u0947\u0915 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0935\u094b \u0906\u092a\u0938\u0947 \u091c\u093c\u094d\u092f\u093e\u0926\u093e \u092e\u091c\u093c\u0947 \u0915\u0930 \u0930\u0939\u0947 \u0939\u0948\u0902",
    "6a": "\u092c\u0927\u093e\u0908 \u0926\u0947\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0905\u0902\u0926\u0930 \u0938\u0947 \u0917\u093f\u0928\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a \u0915\u093f\u0924\u0928\u0947 \u092a\u0940\u091b\u0947 \u0939\u0948\u0902",
    "6b": "\u092c\u093e\u0924\u091a\u0940\u0924 \u0915\u094b \u0905\u092a\u0928\u0940 \u0915\u0930\u093f\u092f\u0930 \u0915\u0940 \u092a\u0930\u0947\u0936\u093e\u0928\u093f\u092f\u094b\u0902 \u0914\u0930 \u092d\u0935\u093f\u0937\u094d\u092f \u0915\u0940 \u092f\u094b\u091c\u0928\u093e\u0913\u0902 \u092a\u0930 \u0918\u0941\u092e\u093e \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",
    "6c": "\u091c\u0936\u094d\u0928 \u092e\u0928\u093e\u0928\u0947 \u0915\u093e \u0935\u093e\u0926\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u092c\u093e\u0930-\u092c\u093e\u0930 \u0930\u0940\u0936\u0947\u0921\u094d\u092f\u0942\u0932 \u0915\u0930\u0924\u0947 \u0930\u0939\u0924\u0947 \u0939\u0948\u0902",
    "6d": "\u092c\u0927\u093e\u0908 \u0938\u0902\u0926\u0947\u0936 \u092d\u0947\u091c\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0905\u0917\u0932\u0947 \u0939\u092b\u094d\u0924\u0947 \u0924\u0915 \u0938\u0940\u0928 \u092a\u0930 \u091b\u094b\u0921\u093c \u0926\u0947\u0924\u0947 \u0939\u0948\u0902",
    "7a": "\u0918\u0930 \u0938\u0947 \u0928\u093f\u0915\u0932\u0947 \u0928\u0939\u0940\u0902 \u0939\u0948\u0902 \u0932\u0947\u0915\u093f\u0928 \"\u092c\u0938 \u092a\u0939\u0941\u0902\u091a \u0917\u092f\u093e!\" \u092d\u0947\u091c\u0924\u0947 \u0939\u0948\u0902",
    "7b": "\u0926\u0947\u0930 \u0938\u0947 \u092a\u0939\u0941\u0902\u091a\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0924\u0941\u0930\u0902\u0924 \u092c\u0924\u093e\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a\u0915\u093e \u0926\u093f\u0928 \u0915\u093f\u0924\u0928\u093e \u092a\u093e\u0917\u0932 \u0925\u093e",
    "7c": "\"\u0915\u0939\u093e\u0902 \u0939\u094b?\" \u092e\u0948\u0938\u0947\u091c \u0907\u0917\u094d\u0928\u094b\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0910\u0938\u0947 \u0906\u0924\u0947 \u0939\u0948\u0902 \u091c\u0948\u0938\u0947 \u0915\u0941\u091b \u0939\u0941\u0906 \u0939\u0940 \u0928\u0939\u0940\u0902",
    "7d": "\u0905\u092a\u0928\u0940 \u0938\u092e\u092f-\u092a\u093e\u0932\u0928 \u0915\u0940 \u0926\u0942\u0938\u0930\u094b\u0902 \u0938\u0947 \u0924\u0941\u0932\u0928\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0914\u0930 \u0924\u092f \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u0906\u092a \u0905\u092d\u0940 \u092d\u0940 \u092c\u0947\u0939\u0924\u0930 \u0939\u0948\u0902"
