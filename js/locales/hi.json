    "serialCanceler": "\u0938\u0940\u0930\u093f\u092f\u0932 \u0915\u0948\u0902\u0938\u0932\u0930",
    "serialCancelerDesc": "\u0909\u0924\u094d\u0938\u093e\u0939 \u0938\u0947 \u092a\u094d\u0932\u093e\u0928 \u092c\u0928\u093e\u0924\u0947 \u0939\u0948\u0902, \u092b\u093f\u0930 \u0938\u0939\u0940 \u092c\u0939\u093e\u0928\u093e \u0922\u0942\u0902\u0922\u0924\u0947 \u0939\u0948\u0902\u0964",
