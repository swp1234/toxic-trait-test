    "passiveAggressorDesc": "\"\u0920\u0940\u0915 \u0939\u0942\u0902\" = \u092c\u093f\u0932\u0915\u0941\u0932 \u0920\u0940\u0915 \u0928\u0939\u0940\u0902\u0964 \u0905\u0930\u094d\u0925\u092a\u0942\u0930\u094d\u0923 \u0906\u0939 \u0915\u0947 \u092e\u093e\u0938\u094d\u091f\u0930\u0964",
    "passiveAggressorEmoji": "\ud83c\udfad",
    "mainCharacter": "\u092e\u0947\u0928 \u0915\u0948\u0930\u0947\u0915\u094d\u091f\u0930",
