    "overPromiserDesc": "\u0938\u092c \u0915\u0941\u091b \u0915\u0947 \u0932\u093f\u090f \u0939\u093e\u0902 \u0915\u0939\u0924\u0947 \u0939\u0948\u0902, \u0906\u0927\u093e \u0939\u0940 \u092a\u0942\u0930\u093e \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964",
    "overPromiserEmoji": "\u2728",
