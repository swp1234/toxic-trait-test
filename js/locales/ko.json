  "tips": {
    "ghoster": "\uc0ac\ub77c\uc9c0\uace0 \uc2f6\uc744 \ub54c, \uc9e7\uc740 \ub2f5\uc7a5\uc774\ub77c\ub3c4 \ubcf4\ub0b4\ubcf4\uc138\uc694. \"\uc2dc\uac04\uc774 \uc880 \ud544\uc694\ud574\"\uac00 \uce68\ubb35\ubcf4\ub2e4 \ub0ab\uc2b5\ub2c8\ub2e4.",
    "overPromiser": "\uc608\uc2a4\ub77c\uace0 \ud558\uae30 \uc804\uc5d0 5\ucd08 \uba48\ucd94\uc138\uc694. \uce98\ub9b0\ub354\ub97c \ud655\uc778\ud558\uc138\uc694. \"\uc0dd\uac01\ud574 \ubcfc\uac8c\"\ub77c\uace0 \ud574\ub3c4 \uad1c\ucc2e\uc2b5\ub2c8\ub2e4.",
    "passiveAggressor": "\uac10\uc815\uc744 \uc9c1\uc811 \ub9d0\ud558\ub294 \uc5f0\uc2b5\uc744 \ud558\uc138\uc694. \"\uad1c\ucc2e\uc544\"\ubcf4\ub2e4 \"...\ud560 \ub54c \uc0c1\ucc98\ubc1b\uc558\uc5b4\"\uac00 \ub354 \uc815\uc9c1\ud569\ub2c8\ub2e4.",
    "mainCharacter": "2:1 \ubc95\uce59\uc744 \uc2dc\ub3c4\ud574 \ubcf4\uc138\uc694 \u2014 \ub0b4 \uc774\uc57c\uae30 1\uac00\uc9c0\ub97c \ud558\uae30 \uc804\uc5d0 \uc0c1\ub300\ubc29\uc5d0\uac8c 2\uac00\uc9c0 \uc9c8\ubb38\uc744 \ud558\uc138\uc694.",
    "serialCanceler": "\uc9c0\uae08 \ub2f9\uc7a5 \uc124\ub808\ub294 \uc57d\uc18d\ub9cc \ud558\uc138\uc694. \uc0ac\uad50 \uc57d\uc18d\uc740 \uc591\ubcf4\ub2e4 \uc9c8\uc774 \uc911\uc694\ud569\ub2c8\ub2e4.",
    "chronicComparer": "\ube44\uad50\ub97c \uc720\ubc1c\ud558\ub294 \uacc4\uc815\uc744 \uc5b8\ud314\ub85c\uc6b0\ud558\uc138\uc694. \ub0b4 \ube44\ud558\uc778\ub4dc\uc640 \ub0a8\uc758 \ud558\uc774\ub77c\uc774\ud2b8\ub97c \ube44\uad50\ud558\uace0 \uc788\ub2e4\ub294 \uac78 \uae30\uc5b5\ud558\uc138\uc694.",
    "general": "\uc790\uae30 \uc778\uc2dd\uc740 \uc131\uc7a5\uc758 \uccab \uac78\uc74c\uc785\ub2c8\ub2e4. \uc774 \ud14c\uc2a4\ud2b8\ub97c \ud55c \uac83 \uc790\uccb4\uac00 \uac10\uc815\uc801 \uc131\uc219\ud568\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4."
  },
