  "question": {
    "0": "\uce5c\uad6c\uac00 \"\uc6b0\ub9ac \uc598\uae30 \uc880 \ud574\uc57c \ub420 \uac83 \uac19\uc544\"\ub77c\uace0 \ubb38\uc790\ub97c \ubcf4\ub0c5\ub2c8\ub2e4. \uc5b4\ub5bb\uac8c \ud558\uc2dc\uaca0\uc5b4\uc694?",
    "1": "\ub204\uad70\uac00 \uc9c1\uc7a5\uc5d0\uc11c \ub2f9\uc2e0\uc758 \uc544\uc774\ub514\uc5b4\ub97c \uc790\uae30 \uac83\ucc98\ub7fc \uac00\uc838\uac11\ub2c8\ub2e4.",
    "2": "\uce5c\uad6c\ub4e4\uacfc \uc57d\uc18d\uc774 \uc788\uc9c0\ub9cc \uc18c\ud30c\uac00 \ub108\ubb34 \ud3b8\ud574 \ubcf4\uc785\ub2c8\ub2e4.",
    "3": "\uce5c\uad6c\uac00 \uba4b\uc9c4 \ud734\uac00 \uc0ac\uc9c4\uc744 \uc62c\ub838\ub294\ub370 \ub2f9\uc2e0\uc740 \uc9c1\uc7a5\uc5d0 \ubb36\uc5ec \uc788\uc2b5\ub2c8\ub2e4.",
    "4": "\uc8fc\ub9d0\uc5d0 \uce5c\uad6c \uc774\uc0ac\ub97c \ub3c4\uc640\uc8fc\uae30\ub85c \ud588\uc2b5\ub2c8\ub2e4.",
    "5": "\ub204\uad70\uac00 \"\ub098\ud55c\ud14c \ud654\ub09c \uac70\uc57c?\"\ub77c\uace0 \ubb3b\uc2b5\ub2c8\ub2e4.",
    "6": "\uce5c\uad6c\uac00 \ud070 \uc2b9\uc9c4\uc744 \ud588\uc2b5\ub2c8\ub2e4.",
    "7": "\ub204\uad70\uac00\ub97c \ub9cc\ub098\ub7ec \uac00\ub294\ub370 20\ubd84 \ub2a6\uace0 \uc788\uc2b5\ub2c8\ub2e4."
  },
  "option": {
    "0a": "\uc77d\uace0 \ud328\ub2c9\uc5d0 \ube60\uc838 3\uc77c\uac04 \ub2f5\uc7a5\uc744 \uc548 \ud55c\ub2e4",
    "0b": "\ud588\uc744 \uc218\ub3c4 \uc548 \ud588\uc744 \uc218\ub3c4 \uc788\ub294 \uc77c\uc5d0 \ub300\ud55c \uc0ac\uacfc \uc2a4\ud53c\uce58\ub97c \uc989\uc2dc \uc900\ube44\ud55c\ub2e4",
    "0c": "\"\uadf8\ub798, \ubb34\uc2a8 \uc77c\uc774\uc57c?\"\ub77c\uace0 \ub2f5\ud558\uace0 4\uc2dc\uac04 \ub3d9\uc548 \ubaa8\ub4e0 \uac00\ub2a5\ud55c \uc758\ubbf8\ub97c \ubd84\uc11d\ud55c\ub2e4",
    "0d": "\uba54\uc2dc\uc9c0\ub97c \ub2e4 \uc77d\uc9c0\ub3c4 \uc54a\uace0 \"\uc751 \ub098\ub3c4\"\ub77c\uace0 \ub2f5\ud55c\ub2e4",
    "1a": "\uc544\ubb34 \ub9d0 \uc548 \ud558\uace0 \uc6d0\ub798 \uc774\uba54\uc77c\uc744 \uc804\uccb4 \ucc38\uc870\ub85c \uc218\ub3d9\uc801\uc73c\ub85c \ubcf4\ub0b8\ub2e4",
    "1b": "\uba38\ub9bf\uc18d\uc73c\ub85c\ub294 \ub530\uc9c4\ub2e4... \ud604\uc2e4\uc5d0\uc120 \uc6c3\uc73c\uba70 \uc18d\uc73c\ub85c \uc8fd\ub294\ub2e4",
    "1c": "\ub0b4\uac00 \uc5b4\ub5bb\uac8c \uadf8 \uc544\uc774\ub514\uc5b4\ub97c \ub0c8\ub294\uc9c0 \uc598\uae30\ud558\uba70 \ub0b4 \ucc9c\uc7ac\uc131\uc73c\ub85c \ud654\uc81c\ub97c \ub3cc\ub9b0\ub2e4",
    "1d": "\uc989\uc2dc \uadf8 \uc0ac\ub78c\uacfc \ube44\uad50\ud558\uba70 \ub0b4\uac00 \uc77c\uc744 \uc798\ud558\ub294\uc9c0 \uc758\uc2ec\ud55c\ub2e4",
    "2a": "\ud558\ub8e8 \uc885\uc77c \uc644\ubcbd\ud558\uac8c \ub9cc\ub4e0 \ucc3d\uc758\uc801\uc778 \ud551\uacc4\ub85c \ucde8\uc18c\ud55c\ub2e4",
    "2b": "\uac00\uc9c0\ub9cc \uc5bc\ub9c8\ub098 \ud53c\uace4\ud55c\uc9c0 \uacc4\uc18d \ud22c\ub36c\ub370\ub294 \ub2e4",
    "2c": "\uc18c\ud30c \uc0ac\uc9c4\uc744 \uc62c\ub9ac\uba70 \"\ub54c\ub860 \uc140\ud504\ucf00\uc5b4\uac00 \uc774\uae34\ub2e4\"\uace0 \ud558\uace0 \ub2e8\uce74\ub97c \ubb34\uc2dc\ud55c\ub2e4",
    "2d": "\uac00\uc11c \ubaa8\uc784\uc5d0\uc11c \ub0b4\uac00 \uac70\uc758 \uc9d1\uc5d0 \uc788\uc744 \ubed4\ud588\ub358 \uc774\uc57c\uae30\ub97c \ubaa8\ub450\uc5d0\uac8c \ud55c\ub2e4",
    "3a": "\uc0ac\uc9c4\uc5d0 \uc88b\uc544\uc694\ub97c \ub204\ub974\uba70 \uc18d\uc73c\ub85c \uadf8\ub4e4\uc758 \uc0b6\uacfc \ub0b4 \uc0b6\uc744 \ube44\uad50\ud55c\ub2e4",
    "3b": "\uadf8\ub4e4\uc744 \uc774\uae30\ub824\uace0 \uc989\uc2dc \ub0b4 \ud734\uac00\ub97c \uacc4\ud68d\ud55c\ub2e4",
    "3c": "\uc751\uc6d0 \ub313\uae00\uc744 \ub2ec\uace0, \ub2e4\ub978 \uc0ac\ub78c\uc5d0\uac8c \uc778\uc0dd\uc774 \uc5bc\ub9c8\ub098 \ubd88\uacf5\ud3c9\ud55c\uc9c0 \ud22c\ub36c\ub308\ub2e4",
    "3d": "\uc815\uc2e0 \uac74\uac15\uc744 \uc704\ud574 \uadf8\ub4e4\uc758 \uc2a4\ud1a0\ub9ac\ub97c \ubba4\ud2b8\ud558\uace0 \ubabb \ubcf8 \ucc99\ud55c\ub2e4",
    "4a": "\ub2a6\uac8c \ucee4\ud53c \ub4e4\uace0 \uc640\uc11c \ub300\ubd80\ubd84 \uac10\ub3c5\ub9cc \ud55c\ub2e4",
    "4b": "\uc544\uce68\uc5d0 \uc218\uc0c1\ud560 \uc815\ub3c4\ub85c \uad6c\uccb4\uc801\uc778 \ud551\uacc4\ub85c \ucde8\uc18c\ud55c\ub2e4",
    "4c": "\uac00\uc9c0\ub9cc \ub0b4 \uc9c0\ub09c \uc774\uc0ac\uac00 \uc5bc\ub9c8\ub098 \ub354 \ud798\ub4e4\uc5c8\ub294\uc9c0 \uacc4\uc18d \uc598\uae30\ud55c\ub2e4",
    "4d": "\ub3c4\uc640\uc900\ub2e4\uace0 \ud558\uba74\uc11c \uac19\uc740 \ub0a0 \ub2e4\ub978 3\uba85\uc5d0\uac8c\ub3c4 \ub2e4\ub978 \uc57d\uc18d\uc744 \ud55c\ub2e4",
    "5a": "\"\uad1c\ucc2e\uc544\" (\uad1c\ucc2e\uc9c0 \uc54a\uc74c)",
    "5b": "\"\uac10\uc815 \uc815\ub9ac\"\ub97c \uc704\ud574 \ud558\ub8e8 \ub3d9\uc548 \ubb34\uc2dc\ud55c\ub2e4",
    "5c": "\ub0b4 \uac10\uc815\uacfc \ub0b4\uac00 \uc5b4\ub5bb\uac8c \uc601\ud5a5\ubc1b\uc558\ub294\uc9c0 20\ubd84\uac04 \ub3c5\ubc31\uc744 \uc2dc\uc791\ud55c\ub2e4",
    "5d": "\uc544\ub2c8\ub77c\uace0 \ud558\uace0 \uc989\uc2dc \uadf8\ub4e4\uc758 \uc778\uc2a4\ud0c0\ub97c \ud655\uc778\ud558\uba70 \ub098\ubcf4\ub2e4 \uc7ac\ubbf8\uc788\uac8c \ub178\ub294\uc9c0 \ubcf8\ub2e4",
    "6a": "\ucd95\ud558\ud558\uba70 \uc18d\uc73c\ub85c \ub0b4\uac00 \uc5bc\ub9c8\ub098 \ub4a4\ucc98\uc838 \uc788\ub294\uc9c0 \uacc4\uc0b0\ud55c\ub2e4",
    "6b": "\ub300\ud654\ub97c \ub0b4 \ucee4\ub9ac\uc5b4 \uace0\ubbfc\uacfc \uc55e\uc73c\ub85c\uc758 \uacc4\ud68d\uc73c\ub85c \ub3cc\ub9b0\ub2e4",
    "6c": "\ucd95\ud558 \ud30c\ud2f0\ub97c \ud574\uc8fc\uaca0\ub2e4\uace0 \ud558\uace0 \uacc4\uc18d \uc77c\uc815\uc744 \ubbf8\ub8ec\ub2e4",
    "6d": "\ucd95\ud558 \ubb38\uc790\ub97c \ubcf4\ub0b4\uace0 \ub2e4\uc74c \uc8fc\uae4c\uc9c0 \uc77d\uc529\uc73c\ub85c \ub0a8\uae34\ub2e4",
    "7a": "\uc9d1\uc5d0\uc11c \uc544\uc9c1 \uc548 \ub098\uc654\uc73c\uba74\uc11c \"\uac70\uc758 \ub2e4 \uc654\uc5b4!\"\ub77c\uace0 \ubcf4\ub0b8\ub2e4",
    "7b": "\ub2a6\uac8c \ub3c4\ucc29\ud574\uc11c \ub0b4 \ud558\ub8e8\uac00 \uc5bc\ub9c8\ub098 \ubbf8\uce5c \ub4ef\uc774 \ubc14\ubb58\ub294\uc9c0 \uc598\uae30\ud55c\ub2e4",
    "7c": "\"\uc5b4\ub514\uc57c?\" \ubb38\uc790\ub97c \ubb34\uc2dc\ud558\uace0 \uc544\ubb34 \uc77c\ub3c4 \uc5c6\uc5c8\ub358 \uac83\ucc98\ub7fc \ub098\ud0c0\ub09c\ub2e4",
    "7d": "\ub0b4 \uc2dc\uac04 \uc5c4\uc218\ub97c \ub2e4\ub978 \uc0ac\ub78c\ub4e4\uacfc \ube44\uad50\ud558\uace0 \uc5ec\uc804\ud788 \ub0b4\uac00 \ub0ab\ub2e4\uace0 \uacb0\ub860 \ub0b4\ub9b0\ub2e4"
  },
