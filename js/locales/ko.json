  "intro": {
    "hook": "\ubaa8\ub4e0 \uc0ac\ub78c\uc5d0\uac8c\ub294 \ubcf8\uc778\ub9cc \ubabb \ubcf4\ub294 \uc0ac\uac01\uc9c0\ub300\uac00 \uc788\uc2b5\ub2c8\ub2e4. \ub2f9\uc2e0\uc758 \uc0ac\uac01\uc9c0\ub300\ub294?",
    "title": "\ub098\uc758 \uc228\uaca8\uc9c4 \ud328\ud134\uc740?",
    "desc": "\uc790\uc2e0\uc744 \uc774\ud574\ud558\ub294 \uac83\uc774 \uc131\uc7a5\uc758 \uccab \uac78\uc74c\uc785\ub2c8\ub2e4. 8\uac00\uc9c0 \uc77c\uc0c1 \uc2dc\ub098\ub9ac\uc624\ub85c \ub098\ub9cc\uc758 \ud589\ub3d9 \ud328\ud134\uc744 \ubc1c\uacac\ud558\uc138\uc694.",
    "value": "\uc790\uae30 \uc778\uc2dd\uc740 \ub354 \ub098\uc740 \uc778\uac04\uad00\uacc4\uc640 \uc131\uc7a5\uc73c\ub85c \uc774\ub04c\ub2c8\ub2e4.",
